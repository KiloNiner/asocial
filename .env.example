# Path to the SQLite database file. Use a mounted volume in production.
DATABASE_PATH=./dev.db

# Public URL of the app; controls the Secure cookie flag and links in notifications.
APP_URL=http://localhost:3000

# Shared secret guarding POST /api/cron/run (header: x-cron-token).
CRON_SECRET=change-me

# Reference timezone for the server-side cron schedule.
TZ=Europe/Copenhagen

# SMTP settings for the email digest channel. Leave SMTP_HOST empty to disable email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="asocial <noreply@example.com>"

# Test-only: freeze "today" (YYYY-MM-DD) for the scheduler. Leave empty in production.
FAKE_TODAY=
